---
import Logo from './Logo.astro';
---

<nav>
  <ul>
    <li class='logo'>
      <a href='/'><Logo /> Tijsvl</a>
      <li><a href='/photo'>Photo</a></li>
      <li><a href='/video'>Video</a></li>
      <li><a href='/about'>About</a></li>
      <li><a href='/contact'>Contact</a></li>
    </li>
  </ul>
</nav>

<style lang='scss'>
  ul {
    display: flex;
    justify-content: end;
    align-items: center;
    gap: var(--space-5);
  }

  a {
    color: inherit;
    text-decoration: none;
    font-size: var(--font-5);
  }

  li:not(:first-child) {
    [aria-current] {
      font-weight: 600;
    }

    a:hover {
      text-decoration: underline;
    }
  }

  .logo {
    margin-right: auto;

    a {
      display: flex;
      gap: inherit;
      align-items: center;
      gap: var(--space-2);
    }
  }
</style>

<script>
  const { pathname } = window.location;
  const currentPage = document.querySelector(`nav a[href="${pathname}"]`);
  currentPage?.setAttribute('aria-current', 'page');
</script>
