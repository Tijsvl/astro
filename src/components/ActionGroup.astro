---
import ShareIcon from '@svg/ShareIcon.astro';
import Beer from '@svg/Beer.astro';
import EmailIcon from '@svg/EmailIcon.astro';
import FacebookIcon from '@svg/FacebookIcon.astro';
import WhatsappIcon from '@svg/WhatsappIcon.astro';
import LinkIcon from '@svg/LinkIcon.astro';
import { randomString } from '@utils/randomString';

type Props = {
  openTo: string;
};

const id = randomString();

const { openTo } = Astro.props;
---

<div class='action-group'>
  <div class='share' data-share>
    <button data-share-action class='action' aria-controls=`share-actions-${id}` aria-expanded='false'>
      <ShareIcon />
      <span>Share Gallery</span>
    </button>
    <ul data-share-action data-open-to={openTo} id=`share-actions-${id}` aria-hidden='true'>
      <li><a href='#' target='_blank' data-share-email><EmailIcon /> E-mail</a></li>
      <li><a href='#' target='_blank' data-share-facebook><FacebookIcon /> Facebook</a></li>
      <li><a href='#' target='_blank' data-share-whatsapp><WhatsappIcon /> Whatsapp</a></li>
      <li><button data-share-copy><LinkIcon /> Copy Link</button></li>
    </ul>
  </div>
  <div class='beer'>
    <a class='action' href='/beer'><Beer /> Buy Me A Beer</a>
  </div>
</div>

<style lang='scss'>
  .action-group {
    display: flex;
    gap: var(--space-5);
    margin-block: var(--space-4);
    align-items: center;

    .action {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      color: var(--color-ink);
      font-size: var(--font-3);
    }
  }

  .share {
    position: relative;
  }

  ul {
    position: absolute;
    left: 0;
    min-width: 100%;
    width: max-content;
    background-color: #fff;
    color: #000;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    z-index: 1;
    border: 1px solid black;
    font-size: 1.25rem;

    &[data-open-to='top'] {
      bottom: calc(100% + 10px);
    }

    &[data-open-to='bottom'] {
      top: calc(100% + 10px);
    }

    &[aria-hidden='true'] {
      display: none;
    }
  }

  li :is(a, button) {
    --icon-size: 20px;
    display: flex;
    align-items: center;
    gap: var(--space-3);

    > svg {
      width: 20px;
    }
  }
</style>

<script>
  const location = window.location.href;
  const pageTitle = document.querySelector('h1')?.textContent;

  const emailEl = document.querySelector('[data-share-email]') as HTMLAnchorElement;
  emailEl.href = 'mailto:?subject=Tijsvl | ' + pageTitle + '&body=' + location;

  const facebookEl = document.querySelector('[data-share-facebook]') as HTMLAnchorElement;
  facebookEl.href = 'https://www.facebook.com/sharer.php?u=' + location;

  const whatsappEl = document.querySelector('[data-share-whatsapp]') as HTMLAnchorElement;
  whatsappEl.href = 'https://api.whatsapp.com/send?text=' + location;

  const toggleShare = (button: HTMLButtonElement, action?: 'CLOSE' | 'OPEN') => {
    let isOpening = button.ariaExpanded === 'false';
    if (action === 'CLOSE') isOpening = false;
    if (action === 'OPEN') isOpening = true;
    const id = button.getAttribute('aria-controls') as string;
    const ul = document.getElementById(id) as HTMLUListElement;

    button.setAttribute('aria-expanded', String(isOpening));
    ul.setAttribute('aria-hidden', String(!isOpening));
  };

  const closeShare = () => {
    const shareButtons = document.querySelectorAll('button[data-share-action]') as NodeListOf<HTMLButtonElement>;
    shareButtons.forEach((button) => toggleShare(button, 'CLOSE'));
  };

  document.addEventListener('click', (e) => {
    const shareButton = (e.target as HTMLElement)!.closest('button[data-share-action]') as HTMLButtonElement;
    const shareUl = (e.target as HTMLElement)!.closest('ul[data-share-action]') as HTMLButtonElement;

    if (shareButton) toggleShare(shareButton);
    if (!shareButton && !shareUl) closeShare();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key == 'Escape') closeShare();
  });
</script>
