---
import Layout from '../layouts/Layout.astro';

const columnCount = 2;

const shuffle = (items: string[], shouldShuffle = true) => {
  const array = [...items];

  if (!shouldShuffle) {
    return array;
  }

  for (let index = array.length - 1; index > 0; index -= 1) {
    const randomIndex = Math.floor(Math.random() * (index + 1));
    [array[index], array[randomIndex]] = [array[randomIndex], array[index]];
  }

  return array;
};

const galleryPhotos = Object.values(import.meta.glob('/public/gallery/*.{jpg,jpeg,png}', { eager: true })) as Array<{
  default: string | { src?: string };
}>;
const photos = shuffle(
  galleryPhotos
    .map((entry) => (typeof entry.default === 'string' ? entry.default : entry.default?.src))
    .filter((src): src is string => Boolean(src)),
  true
);
const photosPerColumn = Math.ceil(photos.length / columnCount);

const columns = Array.from({ length: columnCount }, (_, columnIndex) => {
  const start = columnIndex * photosPerColumn;
  const end = start + photosPerColumn;

  return photos.slice(start, end).map((src) => ({ src }));
});
---

<Layout>
  <article class='gallery' style={`--column-count: ${columnCount};`}>
    {
      columns.map((column) => (
        <section class='column'>
          {column.map(({ src }) => (
            <img src={src} alt='Gallery photo' />
          ))}
        </section>
      ))
    }
  </article>
</Layout>

<style lang='scss'>
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
    align-items: start;

    @media screen and (width > 768px) {
      grid-template-columns: repeat(var(--column-count), minmax(0, 1fr));
    }
  }

  .column {
    display: grid;
    gap: var(--space-2);
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>
